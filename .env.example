# RefereeOS local configuration
#
# Daytona SDK reads DAYTONA_API_KEY, DAYTONA_API_URL, and DAYTONA_TARGET.
# OpenAI is used inside Daytona to interpret the reproducibility receipt.

DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

OPENAI_MODEL=gpt-5.5
OPENAI_API_KEY=
# Keep false unless you explicitly want to send your local OpenAI key into Daytona.
REFEREEOS_PASS_OPENAI_KEY_TO_DAYTONA=false

# Optional AG2/Gemini area-chair synthesis. Leave disabled for deterministic demos.
REFEREEOS_ENABLE_AG2_LLM=false
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_API_KEY=
GOOGLE_GEMINI_API_KEY=
GOOGLE_API_KEY=

REFEREEOS_ALLOW_LOCAL_REPRO_FALLBACK=true
REFEREEOS_OUTPUT_DIR=outputs/runs

# ============================================================
# AG2 Beta agents (ag2_reviewer.py)
# ============================================================
DEEPSEEK_API_KEY=
AG2_MODEL=deepseek-v4-pro
AG2_BASE_URL=https://api.deepseek.com/v1


# ==============================================
# RefereeOS 本地配置文件（适配 DeepSeek-V4-Pro）
# ==============================================

# --------------------------
# 1. Daytona 沙箱配置（可选，没有密钥也能跑基础功能）
# --------------------------
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# --------------------------
# 2. OpenAI/DeepSeek 兼容配置（核心！必须填）
# --------------------------
# 替换为你的 DeepSeek-V4-Pro 真实密钥
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-v4-pro  # 这里专门改成 V4-Pro

# 是否把本地 OpenAI 密钥传给 Daytona（默认false，不用改）
REFEREEOS_PASS_OPENAI_KEY_TO_DAYTONA=false

# --------------------------
# 3. DeepSeek 原生配置（补充，确保全链路兼容）
# --------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro  # 补充原生模型名

# --------------------------
# 4. AG2/Gemini 配置（可选，不用改）
# --------------------------
REFEREEOS_ENABLE_AG2_LLM=false
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_API_KEY=
GOOGLE_GEMINI_API_KEY=
GOOGLE_API_KEY=

# --------------------------
# 5. 本地运行配置（不用改）
# --------------------------
REFEREEOS_ALLOW_LOCAL_REPRO_FALLBACK=true
REFEREEOS_OUTPUT_DIR=outputs/runs

